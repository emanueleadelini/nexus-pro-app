{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Nexus Pro app.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ruolo": { "type": "string", "enum": ["super_admin", "operatore", "referente", "collaboratore", "admin"] },
        "cliente_id": { "type": "string", "description": "Tenant ID for multi-tenancy" },
        "nomeAzienda": { "type": "string" },
        "permessi": { "type": "array", "items": { "type": "string" } },
        "creatoIl": { "type": "string", "format": "date-time" },
        "ultimo_accesso": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "nome_azienda": { "type": "string" },
        "settore": { "type": "string" },
        "logo_url": { "type": "string" },
        "email_riferimento": { "type": "string", "format": "email" },
        "post_totali": { "type": "number" },
        "post_usati": { "type": "number" },
        "include_contratto": { "type": "boolean" },
        "include_visual_identity": { "type": "boolean" },
        "include_offline": { "type": "boolean" },
        "richiesta_upgrade": { "type": "boolean" },
        "richiesta_attenzione": { "type": "boolean" },
        "ai_training": {
          "type": "object",
          "properties": {
            "brand_voice": { "type": "string" },
            "target_audience": { "type": "string" },
            "key_values": { "type": "string" },
            "main_topics": { "type": "string" },
            "competitors": { "type": "string" }
          }
        },
        "creato_il": { "type": "string", "format": "date-time" },
        "aggiornato_il": { "type": "string", "format": "date-time" }
      }
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "properties": {
        "titolo": { "type": "string" },
        "testo": { "type": "string" },
        "stato": { "type": "string", "enum": ["bozza", "revisione_interna", "da_approvare", "revisione", "approvato", "programmato", "pubblicato"] },
        "piattaforme": { "type": "array", "items": { "type": "string" } },
        "formato": { "type": "string" },
        "data_pubblicazione": { "type": "string", "format": "date-time" },
        "materiali_ids": { "type": "array", "items": { "type": "string" } },
        "scadenza_approvazione": { "type": "string", "format": "date-time" }
      }
    },
    "Material": {
      "title": "Material",
      "type": "object",
      "properties": {
        "nome_file": { "type": "string" },
        "url_storage": { "type": "string" },
        "link_esterno": { "type": "string" },
        "caricato_da": { "type": "string" },
        "ruolo_caricatore": { "type": "string", "enum": ["admin", "cliente"] },
        "stato_validazione": { "type": "string", "enum": ["in_attesa", "validato", "rifiutato"] },
        "destinazione": { "type": "string", "enum": ["social", "sito", "offline", "strategico", "visual_identity", "contratto"] },
        "tipo_strategico": { "type": "string", "enum": ["piano_strategico", "piano_comunicazione", "business_plan", "business_model"] },
        "tipo_offline": { "type": "string", "enum": ["brochure", "volantino", "6x3", "3x6", "bigliettini", "gadget", "altro"] },
        "creato_il": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/clienti/{clienteId}": { "schema": "Client", "description": "Tenant data" },
    "/clienti/{clienteId}/post/{postId}": { "schema": "Post", "description": "Post workflow" },
    "/clienti/{clienteId}/materiali/{materialeId}": { "schema": "Material", "description": "Assets" }
  }
}
