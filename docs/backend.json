{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Nexus Agency app.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ruolo": { "type": "string", "enum": ["super_admin", "operatore", "referente", "collaboratore"] },
        "cliente_id": { "type": "string" },
        "nomeAzienda": { "type": "string" },
        "permessi": { "type": "array", "items": { "type": "string" } },
        "creatoIl": { "type": "string", "format": "date-time" }
      }
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "nome_azienda": { "type": "string" },
        "settore": { "type": "string" },
        "logo_url": { "type": "string" },
        "post_totali": { "type": "number" },
        "post_usati": { "type": "number" },
        "include_business_plan": { "type": "boolean" },
        "include_business_model": { "type": "boolean" },
        "richiesta_upgrade": { "type": "boolean" },
        "creato_il": { "type": "string", "format": "date-time" }
      }
    },
    "Notifica": {
      "title": "Notifica",
      "type": "object",
      "properties": {
        "tipo": { "type": "string" },
        "messaggio": { "type": "string" },
        "destinatario_uid": { "type": "string" },
        "letta": { "type": "boolean" },
        "creato_il": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{uid}",
        "definition": {
          "entityName": "User",
          "description": "User profiles with role and permissions."
        }
      },
      {
        "path": "/users/{uid}/notifiche/{notificaId}",
        "definition": {
          "entityName": "Notifica",
          "description": "User-specific notifications for real-time alerts."
        }
      },
      {
        "path": "/clienti/{clienteId}",
        "definition": {
          "entityName": "Client",
          "description": "Main tenant/client data including logos and package flags."
        }
      }
    ]
  }
}