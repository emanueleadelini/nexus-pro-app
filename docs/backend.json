{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Profilo utente con ruolo e associazione cliente.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "ruolo": { "type": "string", "enum": ["admin", "cliente"] },
        "cliente_id": { "type": "string", "description": "ID del cliente associato (solo per ruolo cliente)" },
        "nomeAzienda": { "type": "string" },
        "creatoIl": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "ruolo"]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Azienda cliente e gestione crediti post.",
      "properties": {
        "id": { "type": "string" },
        "nome_azienda": { "type": "string" },
        "settore": { "type": "string" },
        "email_riferimento": { "type": "string" },
        "post_totali": { "type": "number" },
        "post_usati": { "type": "number" },
        "richiesta_upgrade": { "type": "boolean" },
        "creato_il": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome_azienda", "post_totali", "post_usati"]
    },
    "Post": {
      "title": "Post",
      "type": "object",
      "description": "Contenuto del piano editoriale.",
      "properties": {
        "id": { "type": "string" },
        "titolo": { "type": "string" },
        "testo": { "type": "string" },
        "stato": { "type": "string", "enum": ["bozza", "da_approvare", "approvato", "pubblicato"] },
        "materiale_id": { "type": "string" },
        "data_pubblicazione": { "type": "string", "format": "date-time" },
        "creato_il": { "type": "string", "format": "date-time" },
        "aggiornato_il": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "titolo", "testo", "stato"]
    },
    "Material": {
      "title": "Material",
      "type": "object",
      "description": "Asset multimediale o link esterno.",
      "properties": {
        "id": { "type": "string" },
        "nome_file": { "type": "string" },
        "url_storage": { "type": "string" },
        "link_esterno": { "type": "string" },
        "caricato_da": { "type": "string", "description": "UID dell'utente" },
        "stato_validazione": { "type": "string", "enum": ["in_attesa", "validato", "rifiutato"] },
        "destinazione": { "type": "string", "enum": ["social", "sito", "offline"] },
        "note_rifiuto": { "type": "string" },
        "creato_il": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome_file", "caricato_da", "stato_validazione"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "users/{uid}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Profili utenti."
        }
      },
      {
        "path": "clienti/{clienteId}",
        "definition": {
          "entityName": "Client",
          "schema": { "$ref": "#/backend/entities/Client" },
          "description": "Documenti principali dei clienti."
        }
      },
      {
        "path": "clienti/{clienteId}/post/{postId}",
        "definition": {
          "entityName": "Post",
          "schema": { "$ref": "#/backend/entities/Post" },
          "description": "Post del piano editoriale del cliente."
        }
      },
      {
        "path": "clienti/{clienteId}/materiali/{materialId}",
        "definition": {
          "entityName": "Material",
          "schema": { "$ref": "#/backend/entities/Material" },
          "description": "Asset e materiali del cliente."
        }
      }
    ]
  }
}
