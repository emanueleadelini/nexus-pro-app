rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"ruolo": "nessuno"};
    }

    function isSuperAdmin() {
      let data = getUserData();
      return isSignedIn() && (data.ruolo == 'super_admin' || data.ruolo == 'admin');
    }

    function isOperatore() {
      return isSignedIn() && getUserData().ruolo == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isReferente(clientId) {
      let data = getUserData();
      return isSignedIn() && data.ruolo == 'referente' && data.cliente_id == clientId;
    }

    function isCollaboratore(clientId) {
      let data = getUserData();
      return isSignedIn() && data.ruolo == 'collaboratore' && data.cliente_id == clientId;
    }

    function isClient(clientId) {
      return isReferente(clientId) || isCollaboratore(clientId) || (isSignedIn() && getUserData().cliente_id == clientId);
    }

    // --- COLLECTION GROUP (per Admin) ---
    match /{path=**}/post/{postId} {
      allow list: if isAgency();
    }

    match /{path=**}/notifiche/{notificaId} {
      allow list: if isAgency();
    }

    // --- USERS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (request.auth.uid == uid && request.resource.data.ruolo == resource.data.ruolo) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /notifiche/{notificaId} {
        allow read: if request.auth.uid == uid || isAgency();
        allow create: if isSignedIn();
        allow update: if request.auth.uid == uid;
        allow delete: if isAgency();
      }
    }

    // --- CLIENTI ---
    match /clienti/{clienteId} {
      allow get: if isClient(clienteId) || isAgency();
      allow list: if isAgency();
      allow create, update, delete: if isSuperAdmin();

      match /post/{postId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isAgency();
        allow update: if isAgency() || isClient(clienteId);
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isClient(clienteId) || isAgency();
        }
      }

      match /materiali/{materialeId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isClient(clienteId) || isAgency();
        allow update: if isAgency() || isClient(clienteId);
        allow delete: if isAgency();
      }
    }
  }
}