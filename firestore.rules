rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNZIONI HELPER ===
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getAuthProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      // Se il documento esiste, restituisce il ruolo, altrimenti 'none'
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? getAuthProfile().data.ruolo 
        : 'none';
    }

    function isSuperAdmin() {
      return isAuthenticated() && (
        getUserRole() == 'super_admin' || 
        request.auth.token.email == 'emanueleadelini@gmail.com'
      );
    }

    function isOperatore() {
      return isAuthenticated() && getUserRole() == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isClienteOwner(clienteId) {
      return isAuthenticated() && getAuthProfile().data.cliente_id == clienteId;
    }

    function isReferente() {
      return isAuthenticated() && getUserRole() == 'referente';
    }

    // === USERS ===
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      // Permette la creazione e l'aggiornamento del proprio profilo
      // NOTA: In produzione questa regola andrebbe ristretta, ma è necessaria per il setup iniziale
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == uid);
      allow delete: if isSuperAdmin();
    }

    // === CLIENTI ===
    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create, delete: if isSuperAdmin();
      allow update: if isSuperAdmin()
        || (isOperatore() && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['post_totali', 'post_usati']))
        || (isClienteOwner(clienteId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['richiesta_upgrade']));

      // POST
      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && isReferente());
        allow delete: if isAgency();
      }

      // MATERIALI
      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency()
          || (isClienteOwner(clienteId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['stato_validazione', 'note_rifiuto']));
        allow delete: if isAgency();
      }
    }
  }
}