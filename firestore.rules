rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // REGOLE TEMPORANEE PER DEBUG ESTREMO
    // Permettono l'accesso completo a qualsiasi utente autenticato.
    // Utilizzare solo per testare se l'errore persiste a livello di codice o documento.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}