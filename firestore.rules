rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc.data;
    }

    function isSuperAdmin() {
      return isSignedIn() && (getUserData().ruolo == 'super_admin' || request.auth.token.email == 'emanueleadelini@gmail.com');
    }

    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && getUserData().ruolo == 'admin');
    }

    function isAgency() {
      return isAdmin() || (isSignedIn() && getUserData().ruolo == 'operatore');
    }

    function isClientOf(clienteId) {
      return isSignedIn() && getUserData().cliente_id == clienteId;
    }

    // --- USERS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (request.auth.uid == uid) || isAdmin();
      allow delete: if isAdmin();

      match /notifiche/{notificaId} {
        allow read: if request.auth.uid == uid || isAgency();
        allow create: if isSignedIn();
        allow update: if request.auth.uid == uid;
        allow delete: if isAgency();
      }
    }

    // --- CLIENTI ---
    match /clienti/{clienteId} {
      allow get: if isAgency() || isClientOf(clienteId);
      allow list: if isAgency();
      allow create, update, delete: if isAdmin();

      match /post/{postId} {
        allow get, list: if isAgency() || isClientOf(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClientOf(clienteId) && resource.data.stato == 'da_approvare');
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isAgency() || isClientOf(clienteId);
        }
      }

      match /materiali/{materialeId} {
        allow get, list: if isAgency() || isClientOf(clienteId);
        allow create: if isAgency() || isClientOf(clienteId);
        allow update: if isAgency() || isClientOf(clienteId);
        allow delete: if isAgency();
      }
    }

    // REGOLE TEMPORANEE DEBUG (Se necessario scommentare match /{document=**})
    // match /{document=**} { allow read, write: if request.auth != null; }
  }
}
