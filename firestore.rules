rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS AGENCY SECURITY RULES - v10.5
     * 
     * CORE PHILOSOPHY:
     * Protezione multi-tenant con isolamento dei dati per cliente.
     * Consente l'auto-configurazione del primo admin tramite setup key.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToClient(clientId) {
      return isSignedIn() && (
        getUserData().cliente_id == clientId || 
        getUserData().clientId == clientId
      );
    }

    // --- Collection Rules ---

    /** Profilo Utente e Notifiche Personali */
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      // Regole per le notifiche dell'utente
      match /notifiche/{notificaId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isSignedIn();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isOwner(userId) || isAdmin();
      }
    }

    /** Marker per Amministratori (Critico per il setup) */
    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      // Permette la creazione iniziale via Setup Page
      allow create: if isOwner(adminId);
      allow update, delete: if isAdmin(); 
    }

    /** Clienti (Tenant) */
    match /clienti/{clientId} {
      allow get: if isAdmin() || belongsToClient(clientId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      // Post e relativi Commenti
      match /post/{postId} {
        allow get, list: if isAdmin() || belongsToClient(clientId);
        allow create: if isAdmin();
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin();

        match /commenti/{commentoId} {
          allow get, list: if isAdmin() || belongsToClient(clientId);
          allow create: if isAdmin() || belongsToClient(clientId);
          allow update: if isAdmin() || (belongsToClient(clientId) && resource.data.autore_uid == request.auth.uid);
          allow delete: if isAdmin();
        }
      }

      // Asset e Materiali
      match /materiali/{materialId} {
        allow get, list: if isAdmin() || belongsToClient(clientId);
        allow create: if isAdmin() || belongsToClient(clientId);
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin() || (belongsToClient(clientId) && resource.data.uploadedByUserId == request.auth.uid);
      }
    }
  }
}