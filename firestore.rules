rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * NEXUS AGENCY SECURITY RULES - v11.0
     * 
     * GOD MODE: Accesso totale garantito per il proprietario.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Funzione critica per il Super Admin
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == "emanueleadelini@gmail.com";
    }

    function isAdmin() {
      return isSuperAdmin() || (
        isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function belongsToClient(clientId) {
      let userProfile = getUserData();
      return isSignedIn() && (
        userProfile.cliente_id == clientId || 
        userProfile.clientId == clientId
      );
    }

    // --- REGOLE PRIORITARIE ---

    // 1. GOD MODE per Emanuele
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }

    // 2. Supporto per Collection Group Queries (Post, Materiali, Notifiche)
    match /{path=**}/post/{postId} {
      allow read: if isAdmin();
    }
    
    match /{path=**}/materiali/{materialId} {
      allow read: if isAdmin();
    }

    match /{path=**}/notifiche/{notificaId} {
      allow read: if isAdmin();
    }

    // --- REGOLE SPECIFICHE ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();

      match /notifiche/{notificaId} {
        allow read, update: if isOwner(userId) || isAdmin();
        allow create, delete: if isAdmin();
      }
    }

    match /admins/{adminId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update: if isOwner(adminId) || isAdmin();
      allow delete: if isAdmin(); 
    }

    match /clienti/{clientId} {
      allow get: if isAdmin() || belongsToClient(clientId);
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();

      match /post/{postId} {
        allow get, list: if isAdmin() || belongsToClient(clientId);
        allow create: if isAdmin();
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin();

        match /commenti/{commentoId} {
          allow get, list: if isAdmin() || belongsToClient(clientId);
          allow create: if isAdmin() || belongsToClient(clientId);
          allow update: if isAdmin() || (belongsToClient(clientId) && resource.data.autore_uid == request.auth.uid);
          allow delete: if isAdmin();
        }
      }

      match /materiali/{materialId} {
        allow get, list: if isAdmin() || belongsToClient(clientId);
        allow create: if isAdmin() || belongsToClient(clientId);
        allow update: if isAdmin() || (belongsToClient(clientId) && request.resource.data.clientId == resource.data.clientId);
        allow delete: if isAdmin() || (belongsToClient(clientId) && resource.data.uploadedByUserId == request.auth.uid);
      }
    }
  }
}