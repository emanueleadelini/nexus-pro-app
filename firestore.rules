rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : {"ruolo": "nessuno"};
    }

    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'emanueleadelini@gmail.com';
    }

    function isAgency() {
      return isSuperAdmin() || (isSignedIn() && getUserData().ruolo == 'operatore');
    }

    function isClient(clientId) {
      let data = getUserData();
      return isSignedIn() && (data.cliente_id == clientId || isAgency());
    }

    // --- COLLECTION GROUP (per Admin) ---
    match /{path=**}/post/{postId} {
      allow list: if isAgency();
    }

    match /{path=**}/notifiche/{notificaId} {
      allow list: if isAgency();
    }

    // --- USERS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (request.auth.uid == uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /notifiche/{notificaId} {
        allow read: if request.auth.uid == uid || isAgency();
        allow create: if isSignedIn();
        allow update: if request.auth.uid == uid;
        allow delete: if isAgency();
      }
    }

    // --- CLIENTI ---
    match /clienti/{clienteId} {
      allow get: if isClient(clienteId);
      allow list: if isAgency();
      allow create, update, delete: if isSuperAdmin();

      match /post/{postId} {
        allow get, list: if isClient(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || isClient(clienteId);
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isClient(clienteId);
        }
      }

      match /materiali/{materialeId} {
        allow get, list: if isClient(clienteId);
        allow create: if isClient(clienteId);
        allow update: if isAgency() || isClient(clienteId);
        allow delete: if isAgency();
      }
    }
  }
}