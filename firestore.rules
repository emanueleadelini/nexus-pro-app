rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function userHasRole(role) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.ruolo == role;
    }

    function userHasClienteId(clientId) {
      let userDoc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return userDoc != null && userDoc.data.cliente_id == clientId;
    }

    function isSuperAdmin() {
      // Unico admin globale per AD Next Lab
      return isSignedIn() && request.auth.token.email == 'emanueleadelini@gmail.com';
    }

    function isAgency() {
      return isSuperAdmin() || (isSignedIn() && userHasRole('operatore'));
    }

    function isReferente(clientId) {
      return isSignedIn() && userHasRole('referente') && userHasClienteId(clientId);
    }

    function isCollaboratore(clientId) {
      return isSignedIn() && userHasRole('collaboratore') && userHasClienteId(clientId);
    }

    function isClient(clientId) {
      return isReferente(clientId) || isCollaboratore(clientId);
    }

    // --- COLLECTION GROUP (per Admin Dashboard) ---
    match /{path=**}/post/{postId} {
      allow list: if isAgency();
    }

    match /{path=**}/notifiche/{notificaId} {
      allow list: if isAgency();
    }

    // --- USERS ---
    match /users/{uid} {
      allow get: if isSignedIn() && (request.auth.uid == uid || isAgency());
      allow list: if isAgency();
      allow create: if isSignedIn();
      allow update: if (request.auth.uid == uid) || isSuperAdmin();
      allow delete: if isSuperAdmin();

      match /notifiche/{notificaId} {
        allow read: if request.auth.uid == uid || isAgency();
        allow create: if isSignedIn();
        allow update: if request.auth.uid == uid;
        allow delete: if isAgency();
      }
    }

    // --- CLIENTI ---
    match /clienti/{clienteId} {
      allow get: if isClient(clienteId) || isAgency();
      allow list: if isAgency();
      allow create, update, delete: if isSuperAdmin();

      // POST subcollection
      match /post/{postId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isAgency();
        allow update: if isAgency() || isClient(clienteId);
        allow delete: if isAgency();
        
        match /commenti/{commentoId} {
          allow read, write: if isClient(clienteId) || isAgency();
        }
      }

      // MATERIALI subcollection
      match /materiali/{materialeId} {
        allow get, list: if isClient(clienteId) || isAgency();
        allow create: if isClient(clienteId) || isAgency();
        allow update: if isAgency() || isClient(clienteId);
        allow delete: if isAgency();
      }
    }
  }
}