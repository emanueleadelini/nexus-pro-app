rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // === FUNZIONI HELPER ===
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getAuthProfile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) 
        ? getAuthProfile().data.ruolo 
        : 'none';
    }

    function isAdminEmail() {
      return request.auth.token.email == 'emanueleadelini@gmail.com';
    }

    function isSuperAdmin() {
      return isAuthenticated() && (isAdminEmail() || getUserRole() == 'super_admin');
    }

    function isOperatore() {
      return isAuthenticated() && getUserRole() == 'operatore';
    }

    function isAgency() {
      return isSuperAdmin() || isOperatore();
    }

    function isClienteOwner(clienteId) {
      return isAuthenticated() && getAuthProfile().data.cliente_id == clienteId;
    }

    function isReferente() {
      return isAuthenticated() && getUserRole() == 'referente';
    }

    // === USERS ===
    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || isAgency());
      allow create: if isAuthenticated() && request.auth.uid == uid;
      allow update: if isAuthenticated() && (isSuperAdmin() || request.auth.uid == uid);
      allow delete: if isSuperAdmin();
    }

    // === CLIENTI ===
    match /clienti/{clienteId} {
      allow read: if isAgency() || isClienteOwner(clienteId);
      allow create, delete: if isSuperAdmin();
      allow update: if isAgency() || isClienteOwner(clienteId);

      // POST
      match /post/{postId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency();
        allow update: if isAgency() || (isClienteOwner(clienteId) && isReferente());
        allow delete: if isAgency();
        
        // COMMENTI
        match /commenti/{commentoId} {
          allow read: if isAgency() || isClienteOwner(clienteId);
          allow create: if isAuthenticated();
          allow update: if isAgency();
          allow delete: if isSuperAdmin();
        }
      }

      // MATERIALI
      match /materiali/{materialeId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow create: if isAgency() || isClienteOwner(clienteId);
        allow update: if isAgency() || isClienteOwner(clienteId);
        allow delete: if isAgency();
      }

      // CAMPAGNE
      match /campagne/{campagnaId} {
        allow read: if isAgency() || isClienteOwner(clienteId);
        allow write: if isAgency();
      }
    }

    // === NOTIFICHE ===
    match /notifiche/{notificaId} {
      // Un utente può leggere le notifiche se è Admin, Agenzia o il destinatario specifico
      allow read: if isAuthenticated() && (
        isAdminEmail() || 
        isAgency() || 
        resource.data.destinatario_uid == request.auth.uid
      );
      // Creazione permessa dal sistema (client-side) per eventi specifici
      allow create: if isAuthenticated(); 
      // Update permesso per segnare come letta
      allow update: if isAuthenticated() && (isAgency() || resource.data.destinatario_uid == request.auth.uid);
      allow delete: if isSuperAdmin();
    }
  }
}